<footer class="site-footer" role="contentinfo">
  <div class="container footer-inner">
    <section class="footer-brand" aria-label="{{ footer.brand.text }}">
      <a href="{{ footer.brand.href | default('/index.html') }}" class="footer-logo" aria-label="{{ footer.brand.text }} home">
        <span class="footer-logo-icon" aria-hidden="true">
          <svg width="40" height="40" viewBox="0 0 32 32" fill="none">
            <circle cx="16" cy="16" r="14.5" stroke="currentColor" stroke-width="1.5"/>
            <text x="16" y="14" text-anchor="middle" fill="currentColor" font-size="9" font-weight="800" font-family="inherit" letter-spacing="0.5">MC</text>
            <text x="16" y="24" text-anchor="middle" fill="currentColor" font-size="9" font-weight="800" font-family="inherit" letter-spacing="0.5">DA</text>
          </svg>
        </span>
      </a>
      <p class="footer-brand-name">{{ footer.brand.text }}</p>
      <p class="footer-mission">{{ footer.brand.mission }}</p>
      {% if footer.operations.length %}
        <div class="footer-operations">
          {% for op in footer.operations %}
            {% if op.href %}
              <a href="{{ op.href }}">{{ op.label }}</a>{% if not loop.last %}<br>{% endif %}
            {% else %}
              <span>{{ op.label }}</span>{% if not loop.last %}<br>{% endif %}
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    </section>

    <nav class="footer-directory" aria-label="Footer navigation">
      {% for column in footer.columns %}
        <section class="footer-column" aria-label="{{ column.heading }}">
          <h2>{{ column.heading }}</h2>
          <ul>
            {% for link in column.links %}
              <li>
                {% if link.href %}
                  <a href="{{ link.href }}">{{ link.label }}</a>
                {% else %}
                  <span>{{ link.label }}</span>
                {% endif %}
              </li>
            {% endfor %}
          </ul>
        </section>
      {% endfor %}
    </nav>
  </div>
  <div class="container footer-bottom">
    <p class="footer-copy">{{ footer.copyright }}</p>
  </div>
</footer>

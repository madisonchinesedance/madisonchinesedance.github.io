---
layout: layouts/base.njk
---
{% from "partials/gallery.njk" import runner %}

<section class="section page-section">
  <div class="container">
    <div class="section-grid" style="--section-columns:1">
      <article class="section-item" style="--item-index:0">
        <h1 id="home-heading" style="font-size:var(--heading-1-font-size)">{{ homepage.hero.heading }}</h1>
        <div class="component-body"><p>{{ homepage.hero.body }}</p></div>
      </article>
    </div>
  </div>
</section>

<section class="section page-section">
  <div class="container">
    <div class="section-grid" style="--section-columns:1">
      <article class="section-item" style="--item-index:0">
        {{ runner("runner", homepage.runnerImages) }}
      </article>
    </div>
  </div>
</section>

<section class="section page-section section-columns">
  <div class="container">
    <div class="section-grid" style="--section-columns:2">
      {% for stat in homepage.stats %}
        <article class="section-item" style="--item-index:{{ loop.index0 }}">
          <h4 style="font-size:var(--heading-4-font-size)">{{ stat.heading }}</h4>
          <div class="component-body"><p>{{ stat.body }}</p></div>
        </article>
      {% endfor %}
      <article class="section-item" style="--item-index:3">
        {{ runner("runner-tall", homepage.runnerTallImages) }}
      </article>
    </div>
  </div>
</section>

<section class="section page-section section-columns">
  <div class="container">
    <div class="section-grid" style="--section-columns:3">
      {% for card in homepage.cards %}
        <article class="section-item" style="--item-index:{{ loop.index0 }}">
          <h4 style="font-size:var(--heading-4-font-size)">{{ card.heading }}</h4>
          <div class="component-body">
            <p>{{ card.body }}</p>
            <div class="component-actions">
              <a href="{{ card.href }}" class="btn btn-primary" role="button">{{ card.label }}</a>
            </div>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section page-section section-columns">
  <div class="container">
    <div class="section-grid" style="--section-columns:2">
      <article class="section-item" style="--item-index:0">
        <h4 style="font-size:var(--heading-4-font-size)">{{ homepage.story.english.heading }}</h4>
        <div class="component-body json-body-text">
          {% if homepage.story.english.body %}
          {% for para in homepage.story.english.body.split('\n\n') %}
            {% if para.trim() %}<p>{{ para }}</p>{% endif %}
          {% endfor %}
          {% endif %}
        </div>
      </article>
      <article class="section-item" style="--item-index:1">
        <h4 style="font-size:var(--heading-4-font-size)">{{ homepage.story.chinese.heading }}</h4>
        <div class="component-body json-body-text">
          {% if homepage.story.chinese.body %}
          {% for para in homepage.story.chinese.body.split('\n\n') %}
            {% if para.trim() %}<p>{{ para }}</p>{% endif %}
          {% endfor %}
          {% endif %}
        </div>
      </article>
    </div>
  </div>
</section>

<section class="section page-section">
  <div class="container">
    <div class="section-grid" style="--section-columns:1">
      <article class="section-item" style="--item-index:0">
        {{ runner("runner-wide", homepage.runnerWideImages) }}
      </article>
    </div>
  </div>
</section>

<section class="section page-section section-columns">
  <div class="container">
    <div class="section-grid" style="--section-columns:3">
      {% for cta in homepage.ctas %}
        <article class="section-item" style="--item-index:{{ loop.index0 }}">
          <h4 style="font-size:var(--heading-4-font-size)">{{ cta.heading }}</h4>
          <div class="component-body">
            <p>{{ cta.body }}</p>
            <div class="component-actions">
              <a href="{{ cta.href }}" class="btn btn-primary" role="button"{% if cta.href and 'mailto:' in cta.href %} target="_blank" rel="noopener noreferrer"{% endif %}>{{ cta.label }}</a>
            </div>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

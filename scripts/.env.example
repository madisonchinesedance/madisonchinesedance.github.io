# Cloudflare R2 credentials for scan-images.py
# Copy this file to .env and fill in your values, or set these as system
# environment variables. The script reads from environment variables first,
# then falls back to the .env file.

R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY=your_r2_access_key_id
R2_SECRET_KEY=your_r2_secret_access_key
R2_BUCKET=your_bucket_name
R2_PUBLIC_URL=https://your-public-domain.com